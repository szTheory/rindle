{
  "$meta": {
    "name": "rindle",
    "version": "1.0.0",
    "source": "Rindle brand system - this file is the source of truth; tokens.css is generated from it",
    "generated_css": "tokens.css via brandbook/src/tokens-build.mjs"
  },
  "color": {
    "raw": {
      "ink": "#101417",
      "deep-current": "#123A35",
      "deep-current-hover": "#1A4A43",
      "deep-current-active": "#0D2B27",
      "rindle-green": "#32D08C",
      "rind-lime": "#CFEF6A",
      "warm-shell": "#F7F4EA",
      "porcelain": "#FBFEFC",
      "mist": "#E3EAE5",
      "slate": "#52605A",
      "border": "#D9E0DA",
      "border-strong": "#75847B",
      "ready": "#0E7A51",
      "processing": "#6D5DD3",
      "warning": "#9A5C00",
      "danger": "#C83232",
      "quarantine": "#5A4B6B",
      "info": "#2C63D6",
      "ready-surface": "#E0F0E8",
      "processing-surface": "#F4F2FD",
      "warning-surface": "#F6EBD9",
      "danger-surface": "#FCEDED",
      "quarantine-surface": "#ECE7F2",
      "info-surface": "#E5ECFA",
      "code-bg": "#0E1316",
      "code-text": "#D7F8E7",
      "dark-bg": "#0E1316",
      "dark-surface": "#161E23",
      "dark-border": "#2C3840",
      "dark-border-strong": "#5C6E66",
      "dark-text": "#F1F7F3",
      "dark-text-secondary": "#A3B5AC",
      "dark-ready": "#4FD79C",
      "dark-processing": "#A99DEB",
      "dark-warning": "#E2A85B",
      "dark-danger": "#F09090",
      "dark-quarantine": "#BDAED6",
      "dark-info": "#85AAF5"
    },
    "semantic": {
      "light": {
        "surface": "{warm-shell}",
        "surface-raised": "{porcelain}",
        "surface-sunken": "{mist}",
        "text": "{ink}",
        "text-secondary": "{slate}",
        "text-on-brand": "{warm-shell}",
        "brand": "{deep-current}",
        "brand-hover": "{deep-current-hover}",
        "brand-active": "{deep-current-active}",
        "accent": "{rindle-green}",
        "accent-energetic": "{rind-lime}",
        "border-subtle": "{border}",
        "border-strong": "{border-strong}",
        "focus-ring": "{deep-current}",
        "status-ready": "{ready}",
        "status-processing": "{processing}",
        "status-warning": "{warning}",
        "status-danger": "{danger}",
        "status-quarantine": "{quarantine}",
        "status-info": "{info}",
        "status-ready-surface": "{ready-surface}",
        "status-processing-surface": "{processing-surface}",
        "status-warning-surface": "{warning-surface}",
        "status-danger-surface": "{danger-surface}",
        "status-quarantine-surface": "{quarantine-surface}",
        "status-info-surface": "{info-surface}"
      },
      "dark": {
        "surface": "{dark-bg}",
        "surface-raised": "{dark-surface}",
        "surface-sunken": "{ink}",
        "text": "{dark-text}",
        "text-secondary": "{dark-text-secondary}",
        "text-on-brand": "{warm-shell}",
        "brand": "{rindle-green}",
        "brand-hover": "{dark-ready}",
        "brand-active": "{rindle-green}",
        "accent": "{rindle-green}",
        "accent-energetic": "{rind-lime}",
        "border-subtle": "{dark-border}",
        "border-strong": "{dark-border-strong}",
        "focus-ring": "{rindle-green}",
        "status-ready": "{dark-ready}",
        "status-processing": "{dark-processing}",
        "status-warning": "{dark-warning}",
        "status-danger": "{dark-danger}",
        "status-quarantine": "{dark-quarantine}",
        "status-info": "{dark-info}",
        "status-ready-surface": "{dark-surface}",
        "status-processing-surface": "{dark-surface}",
        "status-warning-surface": "{dark-surface}",
        "status-danger-surface": "{dark-surface}",
        "status-quarantine-surface": "{dark-surface}",
        "status-info-surface": "{dark-surface}"
      }
    },
    "rules": {
      "accent-on-light": "rindle-green and rind-lime are accent/large-graphic-only on light surfaces (measured 1.81 / 1.18 vs 4.5 required for text). Text-capable only on ink/dark surfaces.",
      "processing-frozen": "processing #6D5DD3 passes AA on warm-shell at 4.59 with 0.09 margin - never lighten.",
      "status-needs-label": "Never rely on status color alone; always pair with an icon or label."
    }
  },
  "typography": {
    "family": {
      "display": "\"Space Grotesk\", ui-sans-serif, system-ui, sans-serif",
      "sans": "\"Atkinson Hyperlegible\", ui-sans-serif, system-ui, sans-serif",
      "mono": "\"JetBrains Mono\", ui-monospace, SFMono-Regular, Menlo, Consolas, monospace"
    },
    "scale": {
      "hero": { "size": "64px", "line": "1.02", "weight": "700", "family": "display" },
      "h1": { "size": "44px", "line": "1.05", "weight": "700", "family": "display" },
      "h2": { "size": "30px", "line": "1.15", "weight": "600", "family": "display" },
      "h3": { "size": "22px", "line": "1.25", "weight": "600", "family": "display" },
      "body": { "size": "17px", "line": "1.6", "weight": "400", "family": "sans" },
      "small": { "size": "14px", "line": "1.45", "weight": "400", "family": "sans" },
      "code": { "size": "14px", "line": "1.55", "weight": "400", "family": "mono" }
    },
    "rules": {
      "measure": "68-78ch for docs prose",
      "case": "sentence case for headings and UI labels; all-caps only for tiny labels",
      "display-usage": "Space Grotesk for impact, never for paragraphs"
    }
  },
  "spacing": { "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "24px", "6": "32px", "7": "48px", "8": "64px" },
  "radius": {
    "control-sm": "8px",
    "control": "10px",
    "card": "14px",
    "panel": "20px",
    "pill": "999px"
  },
  "border": {
    "subtle": "1px solid {border}",
    "strong": "1px solid {border-strong}"
  },
  "shadow": {
    "card": "0 1px 2px rgba(16, 20, 23, 0.06), 0 8px 24px rgba(16, 20, 23, 0.06)"
  },
  "focus": {
    "width": "2px",
    "offset": "2px",
    "style": "solid",
    "note": "ring color = semantic focus-ring: deep-current on light (11.34:1), rindle-green on dark (9.38:1); both clear the 3:1 non-text requirement. Rindle green on light fails at 1.81 - never use it there."
  },
  "motion": {
    "press": "120ms",
    "popover": "160ms",
    "toast": "200ms",
    "transition": "300ms",
    "diagram": "600ms",
    "easing": "cubic-bezier(0.2, 0, 0, 1)",
    "rules": "materialization, not entertainment; respect prefers-reduced-motion; no bouncing; async progress shows real state"
  },
  "contrast_pairs": [
    { "fg": "ink", "bg": "warm-shell", "min": 4.5, "context": "primary text on main surface" },
    { "fg": "ink", "bg": "porcelain", "min": 4.5, "context": "primary text on cards" },
    { "fg": "slate", "bg": "warm-shell", "min": 4.5, "context": "secondary text" },
    { "fg": "slate", "bg": "porcelain", "min": 4.5, "context": "secondary text on cards" },
    { "fg": "deep-current", "bg": "warm-shell", "min": 4.5, "context": "brand text/headers" },
    { "fg": "warm-shell", "bg": "deep-current", "min": 4.5, "context": "primary button text" },
    { "fg": "warm-shell", "bg": "deep-current-hover", "min": 4.5, "context": "primary button hover" },
    { "fg": "warm-shell", "bg": "deep-current-active", "min": 4.5, "context": "primary button active" },
    { "fg": "rindle-green", "bg": "ink", "min": 4.5, "context": "accent text on dark" },
    { "fg": "rind-lime", "bg": "ink", "min": 4.5, "context": "energetic accent on dark" },
    { "fg": "ready", "bg": "warm-shell", "min": 4.5, "context": "status text" },
    { "fg": "processing", "bg": "warm-shell", "min": 4.5, "context": "status text (frozen, 0.09 margin)" },
    { "fg": "warning", "bg": "warm-shell", "min": 4.5, "context": "status text" },
    { "fg": "danger", "bg": "warm-shell", "min": 4.5, "context": "status text" },
    { "fg": "quarantine", "bg": "warm-shell", "min": 4.5, "context": "status text" },
    { "fg": "info", "bg": "warm-shell", "min": 4.5, "context": "status text" },
    { "fg": "ready", "bg": "ready-surface", "min": 4.5, "context": "ready chip" },
    { "fg": "processing", "bg": "processing-surface", "min": 4.5, "context": "processing chip" },
    { "fg": "warning", "bg": "warning-surface", "min": 4.5, "context": "warning chip" },
    { "fg": "danger", "bg": "danger-surface", "min": 4.5, "context": "danger chip" },
    { "fg": "quarantine", "bg": "quarantine-surface", "min": 4.5, "context": "quarantine chip" },
    { "fg": "info", "bg": "info-surface", "min": 4.5, "context": "info chip" },
    { "fg": "code-text", "bg": "code-bg", "min": 4.5, "context": "code blocks" },
    { "fg": "dark-text", "bg": "dark-bg", "min": 4.5, "context": "dark primary text" },
    { "fg": "dark-text", "bg": "dark-surface", "min": 4.5, "context": "dark text on raised surface" },
    { "fg": "dark-text-secondary", "bg": "dark-bg", "min": 4.5, "context": "dark secondary text" },
    { "fg": "rindle-green", "bg": "dark-bg", "min": 4.5, "context": "dark brand/accent text" },
    { "fg": "dark-ready", "bg": "dark-bg", "min": 4.5, "context": "dark status text" },
    { "fg": "dark-processing", "bg": "dark-bg", "min": 4.5, "context": "dark status text" },
    { "fg": "dark-warning", "bg": "dark-bg", "min": 4.5, "context": "dark status text" },
    { "fg": "dark-danger", "bg": "dark-bg", "min": 4.5, "context": "dark status text" },
    { "fg": "dark-quarantine", "bg": "dark-bg", "min": 4.5, "context": "dark status text" },
    { "fg": "dark-info", "bg": "dark-bg", "min": 4.5, "context": "dark status text" },
    { "fg": "deep-current", "bg": "warm-shell", "min": 3.0, "context": "focus ring on light (non-text)" },
    { "fg": "rindle-green", "bg": "dark-bg", "min": 3.0, "context": "focus ring on dark (non-text)" },
    { "fg": "border-strong", "bg": "porcelain", "min": 3.0, "context": "input/control boundaries (non-text)" },
    { "fg": "border-strong", "bg": "warm-shell", "min": 3.0, "context": "input/control boundaries (non-text)" },
    { "fg": "dark-border-strong", "bg": "dark-bg", "min": 3.0, "context": "dark input boundaries (non-text)" }
  ]
}
